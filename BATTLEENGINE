        Control.Wait(0.5);
        Sound.StopAllSounds();
        Event.Broadcast("unmute");
        Battleover? = 1;
        List.DeleteAll(A Message Log);
    }
    Else
    {
        Control.Wait(0.25);
        If (Enemy < 21)
        {
            Event.Broadcast("mute");
        }
        Sound.PlayUntilDone(die);
        List.Add(A Message Log, "Victory!");
        If (Enemy == 21) //FINAL BOSS FAKE VICTORY, SECOND FORM REVEALS
        {
