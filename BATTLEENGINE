            Control.Wait(1);
            Event.Broadcast("revealfinalboss2nd");
            Control.Wait(1);
            music state = 4;
            Sound.StopAllSounds();
            List.Add(A Message Log, "But then the Dark Spirit reveals its");
            List.Add(A Message Log, "true form - the Spectral Overlord!");
            Enemy = 20;
            List.ReplaceItem(Character/team buffs, 2, 0);
            List.ReplaceItem(Character/team buffs, 8, 0);
