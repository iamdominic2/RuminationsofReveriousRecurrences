            {
                List.Add(A Message Log, "But the monsters were caught off guard!"); 
            }
            Else
            {
                List.Add(A Message Log, Operator.Join("But ", Operator.Join(mon name[Enemy], " was caught off guard!"))); 
            }
            List.ReplaceItem(Character/team buffs, 15, 1);
            Control.Wait(1);
        }
        Else
        {
            If (Operator.Random(1 , 15) == 1)
            {
                If (Enemy No.2 > 0) //BACK ATTACK
                {
                    List.Add(A Message Log, "The monsters suddenly attack!");
                }
                Else
                {
                    List.Add(A Message Log, Operator.Join(mon name[Enemy], " suddenly attacks!"));
                }
                attacker = 1;
                Call Gain Status(13) turns(1) nomsg(1);
                attacker = 2;
                Call Gain Status(13) turns(1) nomsg(1);
                attacker = 3;
                Call Gain Status(13) turns(1) nomsg(1);
                Control.Wait(1);
            }
            Else
            {
            }
        }
    }
    ani x offset = 0;
    Repeat Until (EnemyHP < 1) //THIS IS WHAT OCCURS: THE BATTLE CYCLE.
    {
        Call The BATTLE CYCLE;
    }
    If (Enemy No.2 > 0) //IF THERE ARE TWO ENEMIES IN THE BATTLE, SET IT TO THE ACTIVE TARGET NOW, AND THIS KILLS OFF THE FIRST ONE
    {
        List.ReplaceItem(Character/team buffs, 2, 0);
