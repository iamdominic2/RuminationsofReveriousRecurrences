Define Stun(string who) prob(string p) (warp=false) //CAUSES PAUSED STATUS EFFECT ON PLAYER SIDE WITH A CERTAIN PROBABLITY
{
    attacker = who;
    If (Operator.Random(0 , 1.0) < p)
    {
        Call Gain Status(13) turns(1) nomsg("");
    }
    Else
    {
        If (Operator.LetterOf(Character Status[attacker], 13) < 1)
        {
            List.Add(A Message Log, Operator.Join(Character Names[attacker], " wasn't paused!"));
        }
    }
    Control.Wait(0);
}

Define The BATTLE CYCLE (warp=false) //ADDS AGILITY STATS OF BOTH ENEMY SIDE AND PLAYER SIDE
{
    List.DeleteAll(turn calc);
    List.DeleteAll(turn order);
    Call Add Tcalc (1);
    Call Add Tcalc (2);
    Call Add Tcalc (3);
    Call Add Tcalc (4);
    Call Add Tcalc (5);
    Call Battle Sim;
    Call End of turn effects;
}

Define Turn Order Sort (warp=true) // SORTS THE NUMBERS FROM BIGGEST TO SMALLEST WHEN TURN ORDER IS CALCULATED
{
    counter t = 0;
    attacker = 0;
    Repeat (List.Length(turn calc))
    {
        counter t += 1;
        If (turn calc[counter t] > turn calc[List.IndexOf(turn order, attacker)])
        {
            attacker = turn order[counter t];
        }
    }
    List.DeleteItem(turn calc, List.IndexOf(turn order, attacker));
    List.DeleteItem(turn order, List.IndexOf(turn order, attacker));
}



