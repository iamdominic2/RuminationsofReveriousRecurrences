        Enemy = Enemy No.2;
        EnemyHP = Operator.Round((Operator.Join(Operator.Join(Operator.LetterOf(mon stat AAADDSSHHHHEEEEM[Enemy], 8), Operator.LetterOf(mon stat AAADDSSHHHHEEEEM[Enemy], 9)), Operator.Join(Operator.LetterOf(mon stat AAADDSSHHHHEEEEM[Enemy], 10), Operator.LetterOf(mon stat AAADDSSHHHHEEEEM[Enemy], 11))) / (((Enemy No.2 > 0) / 3) + 1)));
        ani x offset = 33;
        Repeat Until (EnemyHP < 1)
        {
            Call The BATTLE CYCLE;
        }
        Control.Wait(0.24);
        Event.Broadcast("mute");
        Sound.PlayUntilDone(die);
        List.Add(A Message Log, "Victory!");
        Sound.PlayUntilDone(victory-101soundboards);
        togainexp += Operator.Join(Operator.Join(Operator.LetterOf(mon stat AAADDSSHHHHEEEEM[Enemy], 12), Operator.LetterOf(mon stat AAADDSSHHHHEEEEM[Enemy], 13)), Operator.Join(Operator.LetterOf(mon stat AAADDSSHHHHEEEEM[Enemy], 14), Operator.LetterOf(mon stat AAADDSSHHHHEEEEM[Enemy], 15)));
        togainexp = floor((togainexp * 1.1));
        If (Not ((Enemy == 20)))
        {
            Call Pause("");
            Call Ex Tx(1);
            Call Ex Tx(2);
            Call Ex Tx(3);
            Control.Wait(0.2);
