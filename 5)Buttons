    {
        Control.CreateCloneOf(_myself_);
        Motion.ChangeXBy(75);
        Looks.NextCostume();
    }
    Motion.GoToXY(-200, -165);
    Repeat (3)
    {
        Control.CreateCloneOf(_myself_);
        Motion.ChangeXBy(75);
        Looks.NextCostume();
    }
    Motion.GoToXY(-240, -120);
    Looks.SwitchCostumeTo(lol);
    Control.CreateCloneOf(_myself_);
}

